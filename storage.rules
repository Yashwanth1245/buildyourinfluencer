rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /{allPaths=**} {
      // PRO PRIVACY RULES
      // Only the owner of the folder (userId) can read or write!
      // This prevents anyone else from stealing or viewing your persona assets.
      
      match /influencers/{userId}/{fileName} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      match /templates/{allPaths=**} {
        allow read: if true;
        allow write: if false; // Locked to Script/Service Account
      }
      
      match /content/{userId}/{fileName} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      
      match /temp/{userId}/{fileName} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }
  }
}
