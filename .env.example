# PORT for the express server
PORT=3001

# Google Analytics / Gemini API Key
GEMINI_API_KEY=your_gemini_api_key_here

# Fal.ai API Key (format: [key_id]:[key_secret])
FAL_KEY=your_fal_key_here

# Vidgo.ai API Key
VIDGO_API_KEY=your_vidgo_api_key_here

# Primary Administrative Email (for Manage Video Templates access)
ADMIN_EMAIL=kyashwanth1133@gmail.com

# NOTE: You also need a service-account.json file in the root directory.
# Download this from Firebase Console > Project Settings > Service Accounts.
